            </button>
          </div>
        </div>
        
        {/* Scoreboard */}
        <div className="px-10 py-8 bg-gradient-to-r from-brand-blue/10 via-transparent to-brand-green/10 border-b border-white/10">
          <div className="flex items-center justify-between">
