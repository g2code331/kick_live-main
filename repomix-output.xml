                const formData = new FormData(form);
                
                try {
                  await createPlayer({
                    team_id: team.id,
                    name: formData.get('name'),
                    position: formData.get('position'),
                    number: parseInt(formData.get('number') as string),
                    nationality: formData.get('nationality')
