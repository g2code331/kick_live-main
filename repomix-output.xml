          </button>
        </div>
      </aside>

      {/* Main Content */}
      <main className="flex-1 p-4 lg:p-8 overflow-auto pt-20 lg:pt-8">
        {activeTab === 'overview' && (
          <div className="space-y-8">
            <div>
