                <span className="text-4xl font-black">{homeTeam?.short_name?.[0] || 'H'}</span>
              </div>
              <h2 className="text-xl font-black uppercase">{homeTeam?.name || 'Home Team'}</h2>
              <p className="text-xs text-white/40">{homeTeam?.city || ''}</p>
